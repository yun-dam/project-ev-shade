# Vertex AI (Google Cloud) configuration.
# Auth uses Application Default Credentials (ADC) from `gcloud auth application-default login`.
# No API key is stored here; these are non-secret project settings.
GOOGLE_CLOUD_PROJECT=hai-gcp-a-model
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-2.5-pro

# Google Maps Platform API key — ground-level image retrieval ONLY
# (src/retrieve_ground.py). This IS a secret. Separate from the Vertex AI ADC above.
# Enable on the key: Places API (New) + Street View Static API.
GOOGLE_MAPS_API_KEY=

# Optional retrieval tuning (defaults shown):
# NEARBY_RADIUS_M=20.0
# PHOTO_MAX_PX=1600
# STREETVIEW_SIZE=640x480
# STREETVIEW_FOV=90
